rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser() {
      let data = request.resource.data;
      return hasRequiredFields(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['coordenador', 'professor'] &&
             data.createdAt is string;
    }

    function isValidTurma() {
      let data = request.resource.data;
      return hasRequiredFields(['nome', 'ano', 'createdAt', 'createdBy']) &&
             data.nome is string && data.nome.size() > 0 && data.nome.size() < 100 &&
             data.ano is string && data.ano.size() > 0 && data.ano.size() < 50 &&
             data.createdAt is string &&
             data.createdBy is string;
    }

    function isValidAluno() {
      let data = request.resource.data;
      return hasRequiredFields(['nome', 'matricula', 'turmaId', 'createdAt', 'createdBy']) &&
             data.nome is string && data.nome.size() > 0 && data.nome.size() < 100 &&
             data.matricula is string && data.matricula.size() > 0 && data.matricula.size() < 50 &&
             data.turmaId is string &&
             data.createdAt is string &&
             data.createdBy is string;
    }

    function isValidAvaliacao() {
      let data = request.resource.data;
      return hasRequiredFields(['titulo', 'disciplina', 'turmaId', 'dataAplicacao', 'createdAt', 'createdBy']) &&
             data.titulo is string && data.titulo.size() > 0 && data.titulo.size() < 200 &&
             data.disciplina is string && data.disciplina.size() > 0 && data.disciplina.size() < 100 &&
             data.turmaId is string &&
             data.dataAplicacao is string &&
             data.createdAt is string &&
             data.createdBy is string;
    }

    function isValidRespostaAluno() {
      let data = request.resource.data;
      return hasRequiredFields(['avaliacaoId', 'alunoId', 'respostas', 'status', 'createdAt', 'createdBy']) &&
             data.avaliacaoId is string &&
             data.alunoId is string &&
             data.respostas is list &&
             data.status in ['Salvo', 'Pendente', 'Erro'] &&
             data.createdAt is string &&
             data.createdBy is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser();
    }

    match /turmas/{turmaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTurma() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isValidTurma();
      allow delete: if isAuthenticated();
    }

    match /alunos/{alunoId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAluno() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isValidAluno();
      allow delete: if isAuthenticated();
    }

    match /avaliacoes/{avaliacaoId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAvaliacao() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isValidAvaliacao();
      allow delete: if isAuthenticated();
    }

    match /respostas/{respostaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRespostaAluno() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isValidRespostaAluno();
      allow delete: if isAuthenticated();
    }
  }
}
